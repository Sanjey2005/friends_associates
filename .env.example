# Database
MONGO_URI=mongodb+srv://user:password@cluster.example/friends_associates

# App URL used when generating email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT secrets for cookie-based auth
JWT_SECRET_USER=replace-with-a-long-random-user-secret
JWT_SECRET_ADMIN=replace-with-a-long-random-admin-secret

# Email delivery
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Optional script defaults
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
TEST_EMAIL_TO=person@example.com

# Cron protection
CRON_SECRET=replace-with-a-long-random-cron-secret
